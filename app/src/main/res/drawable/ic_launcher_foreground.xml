<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground. Mira aperture mark scaled into the 108dp viewport
     with the 66dp safe zone. Drawn in white-on-teal so it reads against the
     #2A4A4D background defined in ic_launcher_colors.xml. The terracotta
     center matches the brand mark used in-app. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer ring -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:fillColor="#00000000"
        android:pathData="M 24 54 A 30 30 0 1 1 84 54 A 30 30 0 1 1 24 54 Z" />

    <!-- Six filled blades -->
    <group android:pivotX="54" android:pivotY="54" android:rotation="0">
        <path android:fillColor="#FFFFFF" android:fillAlpha="0.22"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="60">
        <path android:fillColor="#FFFFFF" android:fillAlpha="0.30"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="120">
        <path android:fillColor="#FFFFFF" android:fillAlpha="0.22"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="180">
        <path android:fillColor="#FFFFFF" android:fillAlpha="0.30"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="240">
        <path android:fillColor="#FFFFFF" android:fillAlpha="0.22"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="300">
        <path android:fillColor="#FFFFFF" android:fillAlpha="0.30"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>

    <!-- Six stroked blade outlines -->
    <group android:pivotX="54" android:pivotY="54" android:rotation="0">
        <path android:strokeColor="#FFFFFF" android:strokeWidth="1.3"
            android:strokeAlpha="0.85" android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="60">
        <path android:strokeColor="#FFFFFF" android:strokeWidth="1.3"
            android:strokeAlpha="0.85" android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="120">
        <path android:strokeColor="#FFFFFF" android:strokeWidth="1.3"
            android:strokeAlpha="0.85" android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="180">
        <path android:strokeColor="#FFFFFF" android:strokeWidth="1.3"
            android:strokeAlpha="0.85" android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="240">
        <path android:strokeColor="#FFFFFF" android:strokeWidth="1.3"
            android:strokeAlpha="0.85" android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="300">
        <path android:strokeColor="#FFFFFF" android:strokeWidth="1.3"
            android:strokeAlpha="0.85" android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M 54 27 L 74 50 L 54 50 Z" />
    </group>

    <!-- Center terracotta dot -->
    <path
        android:fillColor="#C97A4A"
        android:pathData="M 46.5 54 A 7.5 7.5 0 1 1 61.5 54 A 7.5 7.5 0 1 1 46.5 54 Z" />
</vector>
