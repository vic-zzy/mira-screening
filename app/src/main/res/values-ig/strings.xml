    <string name="onboarding_p1_title">Enyemaka ọkachamara n\'akpa gị</string>
    <string name="onboarding_p1_body">Mira bụ ngwá nyocha nke na-elele foto akpụ nwa mmadụ na gị ma na-atụ aro ma a ga-eziga onye ọrịa. Mkpebi gị nke ahụike ka nọ n\'aka gị.</string>
    <string name="onboarding_p2_title">Nzọụkwụ atọ dị mfe</string>
    <string name="onboarding_p2_body">Kwadebe onye ọrịa ma pịa otu ugboro. Mira na-ese foto atọ ozugbo n\'usoro, na-ahọrọ nke kachasị doo anya, ma gosi ndụmọdụ nwere akara ntụkwasị obi. Gị na-ekpebi ihe ị ga-eme ọzọ.</string>
    <string name="onboarding_p3_title">Nzuzo gị bu ụzọ</string>
    <string name="onboarding_p3_body">Foto ndị ọrịa na-anọ na ekwentị a. Mira anaghị ezigara ya n\'ebe ọ bụla ma ọ bụrụ na ịhọrọ.</string>
