    <!-- Onboarding -->
    <string name="onboarding_p1_title">Specialist-grade help in your pocket</string>
    <string name="onboarding_p1_body">Mira is a screening tool that looks at the cervix image with you and suggests whether to refer the patient. Your clinical judgment is still in charge.</string>
    <string name="onboarding_p2_title">Three simple steps</string>
    <string name="onboarding_p2_body">Prepare the patient and tap once. Mira takes three quick photos in a row, picks the sharpest, and shows a suggestion with a confidence score. You decide what to do next.</string>
    <string name="onboarding_p3_title">Your privacy comes first</string>
    <string name="onboarding_p3_body">Patient images stay on this phone. Mira never sends them anywhere unless you choose to.</string>
    <string name="onboarding_get_started">Get started</string>

